rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    
    // Helper function to check if user is admin by looking up admin_users collection
    function isAdmin() {
      return request.auth != null && 
             exists(/databases/$(database)/documents/admin_users/$(request.auth.uid)) &&
             get(/databases/$(database)/documents/admin_users/$(request.auth.uid)).data.isActive == true;
    }
    
    // Helper function to check if user is authenticated
    function isAuthenticated() {
      return request.auth != null;
    }
    
    // Admin Users Collection - Super restricted
    match /admin_users/{userId} {
      allow read: if isAuthenticated() && request.auth.uid == userId;
      allow write: if false; // Only system can create admin users via scripts
    }
    
    // User Security Collection - System only
    match /user_security/{email} {
      allow read, write: if false; // System operations only
    }
    
    // Login Attempts Collection - Audit trail
    match /login_attempts/{attemptId} {
      allow read: if isAdmin(); // Only admins can view login attempts
      allow create: if true; // Allow logging all attempts
      allow update, delete: if false; // Immutable audit trail
    }
    
    // CSF Templates Collection - Admin management
    match /csf_templates/{templateId} {
      allow read: if true; // Public read for customer access via URL
      allow write: if isAdmin(); // Only admins can create/modify templates
      allow delete: if isAdmin(); // Only admins can delete templates
    }
    
    // CSF Responses Collection - Customer submissions
    match /csf_responses/{responseId} {
      allow read: if isAdmin(); // Admins can read all responses
      allow create: if true; // Customers can submit responses
      allow update: if false; // Responses are immutable once submitted
      allow delete: if isAdmin(); // Only admins can delete (for cleanup)
    }
    
    // Email Notifications Collection - System tracking
    match /email_notifications/{notificationId} {
      allow read: if isAdmin(); // Admins can view email logs
      allow create, update: if isAdmin(); // Admins can manage notifications
      allow delete: if isAdmin(); // Admins can cleanup old notifications
    }
    
    // System Configuration Collection - Admin settings
    match /system_config/{configId} {
      allow read: if isAdmin(); // Admins can read config
      allow write: if isAdmin(); // Admins can modify config
    }
    
    // Analytics Collection - System metrics
    match /analytics/{metricId} {
      allow read: if isAdmin(); // Admins can view analytics
      allow write: if isAdmin(); // System can update metrics
    }
    
    // Default rule - deny all other access
    match /{document=**} {
      allow read, write: if false;
    }
  }
}